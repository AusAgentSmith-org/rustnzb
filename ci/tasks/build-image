#!/bin/sh
set -eu
. "$(dirname "$0")/lib.sh"
task_start build-image docker

: "${GIT_AUTH_TOKEN:?GIT_AUTH_TOKEN is required for the Forgejo rollback image registry}"
image=${1:-rustnzb:local}
build_ref=${RUSTNZB_BUILD_REF:-$(git rev-parse --short=12 HEAD)}
docker_config=$(mktemp -d)
# Parallel Woodpecker steps share the host Docker daemon and commonly run this
# script with the same container-local PID. Derive the builder name from the
# unique temporary directory so one step's EXIT trap cannot remove another
# step's active BuildKit container.
builder=rustnzb-build-$(basename "$docker_config")
mkdir -p "$docker_config/cli-plugins"
if [ -x "$HOME/.docker/cli-plugins/docker-buildx" ]; then
    ln -s "$HOME/.docker/cli-plugins/docker-buildx" "$docker_config/cli-plugins/docker-buildx"
fi
cleanup() {
    docker buildx rm "$builder" >/dev/null 2>&1 || true
    rm -rf "$docker_config"
    unset GIT_AUTH_TOKEN
}
trap cleanup EXIT
export DOCKER_CONFIG=$docker_config
printf '%s' "$GIT_AUTH_TOKEN" | docker login repo.indexarr.net \
    --username x-access-token --password-stdin >/dev/null
docker buildx create --name "$builder" --driver docker-container --use >/dev/null

set -- \
    --file Dockerfile \
    --target runtime \
    --platform "${RUSTNZB_PLATFORM:-linux/amd64}" \
    --provenance=false \
    --build-arg "RUSTNZB_BUILD_REF=$build_ref" \
    --tag "$image"
if [ "${RUSTNZB_PUSH:-false}" = true ]; then
    set -- "$@" --push
else
    set -- "$@" --load
fi
if [ -n "${RUSTNZB_CACHE_IMAGE:-}" ]; then
    set -- "$@" \
        --cache-from "$RUSTNZB_CACHE_IMAGE" \
        --cache-to "type=registry,ref=$RUSTNZB_CACHE_IMAGE,mode=max,image-manifest=true,oci-mediatypes=true"
fi
if [ "${CI_COLD_CACHE:-false}" = true ]; then
    set -- "$@" --no-cache
fi
docker buildx build "$@" .
